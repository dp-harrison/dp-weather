{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 2,
  "name": "dp/weather",
  "version": "1.0.0",
  "title": "DP Weather",
  "category": "widgets",
  "icon": "cloud",
  "description": "Display a multi-day weather forecast for a location using a public API.",
  "textdomain": "dp-weather",
  "attributes": {
    "locationName": { "type": "string", "default": "London, UK" },
    "latitude": { "type": "number", "default": 51.5072 },
    "longitude": { "type": "number", "default": -0.1276 },
    "units": { "type": "string", "default": "metric" },
    "numberOfDays": { "type": "number", "default": 7 }
  },
  "supports": {
    "multiple": true,
    "inserter": true,
    "customClassName": true,
    "html": false
  },
  "editorScript": "file:./assets/block.js",
  "style": "file:./assets/block-style.css"
}